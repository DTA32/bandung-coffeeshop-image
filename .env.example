# --- R2 (S3-compatible) connection ------------------------------------------
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=bdgcafe
# Optional: override the derived https://<account_id>.r2.cloudflarestorage.com
# R2_ENDPOINT=

# --- Image serving -----------------------------------------------------------
WATERMARK_KEY=watermark.png

# Comma- or newline-separated R2 object paths served WITHOUT a watermark.
#   exact     logos/bdgcafe-logo.png   -> only that object
#   folder    partners/                -> trailing "/" = prefix match
#   wildcard  promos/2026-*            -> trailing "*" = prefix match
WATERMARK_BYPASS=

# --- Cache -------------------------------------------------------------------
# On-disk cache of rendered output. Leave empty to disable (e.g. when a CDN
# in front already caches via the immutable Cache-Control header).
CACHE_DIR=.cache
